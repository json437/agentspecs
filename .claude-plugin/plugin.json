{
  "name": "agentspecs",
  "version": "0.1.0",
  "description": "Turn specs into beautiful, interactive documents with live preview, version history, and inline feedback.",
  "author": {
    "name": "agentspecs"
  },
  "homepage": "https://github.com/json437/agentspecs",
  "repository": "json437/agentspecs",
  "license": "MIT",
  "keywords": ["specs", "documentation", "mcp", "preview", "feedback"],
  "category": "productivity",
  "mcpServers": {
    "agentspecs": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/dist/src/server/index.js"],
      "env": {
        "NODE_PATH": "${CLAUDE_PLUGIN_DATA}/node_modules"
      }
    }
  }
}
